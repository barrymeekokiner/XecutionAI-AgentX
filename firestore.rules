rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidExecutionResult(data) {
      return data.keys().hasAll(['id', 'timestamp', 'input', 'mode', 'riskReport', 'fastActionChecklist']) &&
             data.id is string && data.id.size() <= 128 &&
             data.timestamp is number &&
             data.input is string && data.input.size() <= 5000 &&
             data.mode is string &&
             data.riskReport is map &&
             data.fastActionChecklist is list && data.fastActionChecklist.size() <= 100;
    }

    function isValidAppSettings(data) {
      let keys = data.keys();
      return keys.hasAll(['tier', 'model']) &&
             data.tier in ['free', 'standard', 'premium', 'enterprise'] &&
             data.model is string &&
             (data.apiKey == null || (data.apiKey is string && data.apiKey.size() <= 512)) &&
             (data.customSystemInstruction == null || data.customSystemInstruction is string) &&
             (data.neuralIntensity == null || data.neuralIntensity is number) &&
             (data.customCpuThreshold == null || data.customCpuThreshold is number) &&
             (data.customMemoryThreshold == null || data.customMemoryThreshold is number);
    }

    // Collection Matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'settings', 'customThresholds']);
      
      match /results/{resultId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExecutionResult(incoming());
        allow delete: if isOwner(userId);
      }

      match /settings/global {
        allow get: if isOwner(userId);
        allow write: if isOwner(userId) && isValidAppSettings(incoming());
      }

      match /usage/meter {
        allow read: if isOwner(userId);
        allow write: if false; // Only server-side updates
      }

      match /metrics/{metricId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /alerts/{alertId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
      }
    }

    match /telemetry/{logId} {
      allow create: if isSignedIn();
      allow read: if false; 
    }

    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /teams/enterprise_config {
      allow read: if true;
    }

    match /teams/{teamId} {
      allow read: if teamId == 'enterprise_config' || 
                   (request.auth != null && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.memberUids));
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /audit_logs/{logId} {
        allow read: if isSignedIn(); 
        allow create: if isSignedIn();
      }
    }

    match /system_config/{configId} {
      // The server needs to read the gemini pool.
      // If the server is subject to rules, we allow read if unauthenticated (assuming server doesn't sign in)
      // This is slightly risky but necessary if dbAdmin is hitting rules.
      allow read: if !isSignedIn() && configId == 'gemini_pool';
      allow write: if false; 
    }
  }
}
